/*
========================================================================================
    Configurazione Pipeline ATAC/ChIP-seq - FIXED
========================================================================================
*/

plugins {
    id 'nf-amazon'
}

aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

params {
    // --- INPUT E OUTPUT ---
    input            = "samplesheet.csv"
    protocol         = "chip"            
    outdir           = "results"
    publish_dir_mode = 'copy'

    // --- GENOMA E RIFERIMENTI ---
    // Rimuoviamo il valore fisso 'hg38' per evitare conflitti quando usi --fasta_file
    genome           = null 
    igenomes_base    = 's3://ngi-igenomes/igenomes'
    
    // --- PARAMETRI DI OVERRIDE ---
    bowtie2_index    = null 
    fasta_file       = null
    gtf_file         = null
    blacklist_file   = null
    macs_gsize       = null 

    // Inizializziamo genomes come mappa vuota per evitare errori se igenomes.config fallisce
    genomes          = [:]
}

process.shell = ['/bin/bash', '-euo', 'pipefail']

// Includiamo igenomes.config
// Se il file non esiste o il genoma è custom, la logica in analysis.nf gestirà il resto
includeConfig 'conf/igenomes.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry   = 'quay.io'
    }
}

executor {
    queueSize = 8 
}

/*
========================================================================================
    CONFIGURAZIONE PROCESSI
========================================================================================
*/

process {
    cpus   = 2
    memory = '4 GB'

    withName: BOWTIE2_BUILD {
        cpus   = 8
        memory = '32 GB'
        publishDir = [ path: "${params.outdir}/00_genome_index", mode: params.publish_dir_mode ]
    }

    withName: FASTQC {
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: params.publish_dir_mode ]
    }

    withName: TRIMGALORE {
        cpus   = 4
        memory = '8 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: params.publish_dir_mode ]
    }

    withName: BOWTIE2 {
        cpus   = 12
        memory = '32 GB'
        publishDir = [ path: "${params.outdir}/03_aligned/raw_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_SORT {
        cpus   = 6
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/03_aligned/sorted_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_STATS {
        publishDir = [ path: "${params.outdir}/03_aligned/stats", mode: params.publish_dir_mode ]
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 4
        memory = '24 GB'
        ext.args   = '--REMOVE_DUPLICATES true --ASSUME_SORTED true --VALIDATION_STRINGENCY LENIENT --CREATE_INDEX true'
        publishDir = [ path: "${params.outdir}/04_duplicates_removed", mode: params.publish_dir_mode ]
    }

    withName: FILTERING {
        cpus   = 4
        memory = '12 GB'
        publishDir = [ path: "${params.outdir}/05_final_filtered_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_INDEX {
        publishDir = [ path: "${params.outdir}/05_final_filtered_bam", mode: params.publish_dir_mode ]
    }

    withName: DEEPTOOLS {
        cpus   = 8
        memory = '20 GB'
        publishDir = [ path: "${params.outdir}/06_bigwig", mode: params.publish_dir_mode ]
    }

    withName: 'MACS3_.*' {
        cpus   = 4
        memory = '16 GB'
    }

    withName: 'MACS3_.*_NARROW' {
        publishDir = [ path: "${params.outdir}/07_peaks/narrow", mode: params.publish_dir_mode ]
    }

    withName: 'MACS3_.*_BROAD' {
        publishDir = [ path: "${params.outdir}/07_peaks/broad", mode: params.publish_dir_mode ]
    }

    withName: CALC_FRIP {
        cpus   = 4
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/07_peaks/frip_stats", mode: params.publish_dir_mode ]
    }

    withName: HOMER_ANNOTATEPEAKS {
        cpus   = 6
        memory = '16 GB'
        publishDir = [ 
            path: { it.contains('narrow') ? "${params.outdir}/08_annotation/narrow" : "${params.outdir}/08_annotation/broad" }, 
            mode: params.publish_dir_mode 
        ]
    }

    withName: MULTIQC {
        publishDir = [ path: "${params.outdir}/00_MultiQC_Report", mode: params.publish_dir_mode ]
    }
}
